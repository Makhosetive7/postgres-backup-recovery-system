# ============================================
# PostgreSQL Backup & Recovery System
# Environment Configuration
# ============================================

# PostgreSQL Database Connection (Neon)
# 1. Create project at https://neon.tech
# 2. Dashboard → Connection string → copy (pooled or direct both work for pg_dump)
# 3. Ensure sslmode=require is in the URL (Neon requires SSL)
# 4. Wrap in single quotes if the URL contains & (otherwise bash breaks on source)
DATABASE_URL='postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require'

# Optional: direct (non-pooler) URL for pg_dump/pg_restore — required on Neon if DATABASE_URL uses -pooler
# DATABASE_URL_DIRECT='postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require'

# Backup Configuration
BACKUP_DIR=./backups
WAL_ARCHIVE_DIR=./wal_archive

# Retention Policy (in days)
DAILY_RETENTION=7
WEEKLY_RETENTION=4
MONTHLY_RETENTION=3

# Monitoring & Alerts (optional)
NOTIFY_EMAIL=your.email@example.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Cloudflare R2 (optional - for off-site storage)
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=pg-backups
R2_ENDPOINT=https://account-id.r2.cloudflarestorage.com

# Recovery Targets
# RPO (Recovery Point Objective): Maximum acceptable data loss
RPO_HOURS=1

# RTO (Recovery Time Objective): Maximum acceptable downtime
RTO_HOURS=4
